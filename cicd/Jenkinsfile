pipeline {
    agent any

    tools {
        maven 'maven_3'
    
    }

    environment {
        DOCKER_IMAGE = "sravani2310/taskflow:BUILD_NUMBER"
        DOCKER_UI_IMAGE = "sravani2310/taskflow-ui:BUILD_NUMBER"


        GIT_REPO_NAME = "taskflow-devop"
        GIT_USER_NAME = "SravaniTatini"
 
        APP_DIR_BACKEND = "app/taskflow"
        APP_DIR_FRONTEND = "app/taskflow-ui"
    
    }

    stages {

        // ------------------- CHECKOUT ---------------------------------------
        stage('Checkout') {
            steps {
                echo "✅ Cloning GitHub Repo"
                git branch: 'main', url: "https://github.com/${GIT_USER_NAME}/${GIT_REPO_NAME}.git"
            }
        }

       // ---------------------- BACKEND ----------------------------------------

        stage('Building WAR') {
            steps {
                echo "✅ Building Spring Boot Application "
                dir("$APP_DIR_BACKEND") {
                    sh "mvn clean package -DskipTests"
                    sh "ls -ltr target"
                }
            }
        }

       stage('SonarQube Analysis') {
           steps {
               dir("$APP_DIR_BACKEND") {
                    echo "✅ Running SonarQube Analysis"
                   withSonarQubeEnv('SonarQube') {
                      sh '''
                      mvn sonar:sonar \
                     -Dsonar.projectkey=taskflow \
                     -Dsonar.projectName=taskflow \
                     '''
                    }
                }
            }
        }

        stage('Building Docker Image') {
            steps {
                echo "✅ Building Docker image"
                sh '''
                    docker build -t ${DOCKER_IMAGE}:${BUILD_NUMBER} -f app/taskflow/Dockerfile app/taskflow
                    docker tag ${DOCKER_IMAGE}:${BUILD_NUMBER} ${DOCKER_IMAGE}:latest
                '''
            }
        }


        stage('Trivy Scan- Backend') {
            steps {
                echo "✅ Trivy Security scan for Docker image"
                sh '''
                TMPDIR=/home/jenkins/tmp trivy image \
                --scanners vuln \
                --severity CRITICAL \
                --exit-code 0 \
                --no-progress \
                ${DOCKER_IMAGE}:${BUILD_NUMBER}
             '''
             }
        }

        stage('Push Docker Image') {
            steps {
                echo "✅ Pushing image to DockerHub"
                withCredentials([usernamePassword(credentialsId: 'dockerhub', usernameVariable: 'DOCKER_USER', passwordVariable: 'DOCKER_PASS')]) {
                    sh '''
                        echo "$DOCKER_PASS" | docker login -u "$DOCKER_USER" --password-stdin
                    '''
                }

                sh '''
                    docker push ${DOCKER_IMAGE}:${BUILD_NUMBER}
                '''
            }
        }

        // ----------------------- FRONTEND ---------------------------------------
          
        stage('Build React App') {
            steps {
                dir("$APP_DIR_FRONTEND") {
                    sh '''
                        export REACT_APP_API_URL=${REACT_APP_API_URL}
                        npm install
                        npm run build
                    '''
                }
            }
        }

        stage('Build Docker Image - UI') {
            steps {
                echo "✅ Building Docker image for UI"
                sh '''
                    docker build -t ${DOCKER_UI_IMAGE}:${BUILD_NUMBER} -f app/taskflow-ui/Dockerfile app/taskflow-ui
                    docker tag ${DOCKER_UI_IMAGE}:${BUILD_NUMBER} ${DOCKER_UI_IMAGE}:latest
                '''
            }
        }   

        stage('Trivy Scan- UI') {
            steps {
                echo "✅ Trivy Security scan for Docker image"
                sh '''
                TMPDIR=/home/jenkins/tmp trivy image \
                --scanners vuln \
                --severity CRITICAL \
                --exit-code 0 \
                --no-progress \
                ${DOCKER_UI_IMAGE}:${BUILD_NUMBER}
             '''
             }
        }

        stage('Push UI Docker Image') {
            steps {
                echo "✅ Pushing UI image to DockerHub"
                withCredentials([usernamePassword(credentialsId: 'dockerhub', usernameVariable: 'DOCKER_USER', passwordVariable: 'DOCKER_PASS')]) {
                    sh '''
                        echo "$DOCKER_PASS" | docker login -u "$DOCKER_USER" --password-stdin
                    '''
                }

                sh '''
                    docker push ${DOCKER_UI_IMAGE}:${BUILD_NUMBER}
                '''
            }
        }

        // ----------------------- UPDATING KUBERNETES MANIFESTS ----------------------------

        stage('Update Kubernetes Manifests') {
           steps {
                echo "✅ Updating Kubernetes manifests with new image tags"
                sh '''
                   sed -i "s|image: sravani2310/taskflow:.*|image: ${DOCKER_IMAGE}:${BUILD_NUMBER}|g" k8s/backend-deployment.yaml
                   sed -i "s|image: sravani2310/taskflow-ui:.*|image: ${DOCKER_UI_IMAGE}:${BUILD_NUMBER}|g" k8s/ui-deployment.yaml
                '''
            }
        }

       // ----------------------- COMMIT & PUSH TO GITHUB ----------------------------

        stage('Push to GitOps Repo') {
           steps {
               withCredentials([usernamePassword(credentialsId: 'github-creds', usernameVariable: 'GIT_USER', passwordVariable: 'GIT_PASS')]) {
                  sh '''
                    git config user.name "jenkins"
                    git config user.email "jenkins@local"

                    git add .
                    git commit -m "Update image tag to ${BUILD_NUMBER}" || echo "No changes"

                    git push https://${GIT_USER}:${GIT_PASS}@github.com/${GIT_USER_NAME}/${GIT_REPO_NAME}.git HEAD:main
                   '''
                }
            }
        }
    }


    post {
        success {
            echo "Build Successful 🎉"
        }
        failure {
            echo "Build Failed ❌"
        }
    }
}
    